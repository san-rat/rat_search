{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rat Search",
  "version": "0.1.0",
  "identifier": "com.sanuk.ratsearch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rat Search",
        "width": 704,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/usr/share/icons/**",
          "/usr/share/pixmaps/**",
          "/usr/local/share/icons/**",
          "/var/lib/snapd/desktop/icons/**",
          "$HOME/.icons/**",
          "$HOME/.local/share/icons/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
